# Tessera tuning configuration
# Profile sets defaults; this file overrides them per-project.
# Gitignored by default. Add to .gitignore if not already present.

# Auto-compact window override (default: 400000)
# claude_code_auto_compact_window: 400000

# Bcrypt rounds (standard default: 12; healthcare: 13-14)
# bcrypt_rounds: 12

# TLS minimum version (standard default: 1.2; healthcare: 1.3)
# tls_minimum: "1.2"

# Coverage threshold (default: 80)
# coverage_threshold: 80

# Mnemos fatigue band thresholds (advanced; leave default unless tuning)
# mnemos:
#   flow_band: [0.0, 0.3]
#   compress_band: [0.3, 0.6]
#   pre_sleep_band: [0.6, 0.85]

# Suggestion-gate calibration (advanced; leave default unless tuning)
# suggestion_gate:
#   auto_offer_threshold: 0.7
