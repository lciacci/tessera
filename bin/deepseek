#!/usr/bin/env python3
"""DeepSeek V4 CLI — calls DeepSeek API via Anthropic-compatible endpoint.

Usage:
  deepseek "prompt"                    # Uses default model (pro)
  deepseek --flash "prompt"            # Uses deepseek-v4-flash
  deepseek --pro "prompt"              # Uses deepseek-v4-pro (default)
  echo "prompt" | deepseek             # Read from stdin
  cat file.txt | deepseek --flash      # Pipe mode
"""

# Runs on ANY python3 — including macOS's /usr/bin/python3 (3.9), which a PATH can hand
# you at any time. `#!/usr/bin/env python3` resolves a NAME, and the name's VERSION drifts
# with it. PEP-604 annotations (`str | None`) raise TypeError at definition time on 3.9.
# `from __future__ import annotations` makes them lazy strings. Do not remove.
from __future__ import annotations

import json
import os
import sys
import urllib.error
import urllib.request

# STDLIB ONLY — on purpose, and enforced by doccheck `bin-scripts-are-stdlib-only`.
#
# This file used to `import httpx`. httpx is installed NOWHERE on this machine — not in the
# venv, not in any Homebrew python — so `deepseek` had never run, ever, on any interpreter.
# It failed with ModuleNotFoundError, `bin/validate-plan` caught that and scored it as a
# reviewer VOTING NO, and Tessera's council reported a confident `CHANGES_NEEDED 0/3` built
# entirely out of this. (2026-07-13, FOCUS-004.)
#
# The fix is NOT to add httpx to the venv. `bin/` is reached through a bare interpreter NAME,
# and a name resolves through a PATH four package managers write to — so bin/ must import only
# what the oldest interpreter that PATH can hand it already has. urllib does this POST fine.
API_KEY = os.environ.get("DEEPSEEK_API_KEY", "")
BASE_URL = "https://api.deepseek.com/anthropic"

MODELS = {
    "flash": "deepseek-v4-flash",
    "pro": "deepseek-v4-pro",
}


def main():
    model_key = "pro"
    prompt = None

    args = sys.argv[1:]
    i = 0
    while i < len(args):
        if args[i] in ("--flash", "-f"):
            model_key = "flash"
        elif args[i] in ("--pro", "-p"):
            model_key = "pro"
        elif args[i] == "--model":
            i += 1
            if i < len(args):
                model_key = args[i]
        elif not args[i].startswith("-"):
            prompt = args[i]
        i += 1

    if not API_KEY:
        print("[deepseek] ERROR: DEEPSEEK_API_KEY not set", file=sys.stderr)
        sys.exit(1)

    if not prompt and not sys.stdin.isatty():
        prompt = sys.stdin.read().strip()

    if not prompt:
        print("Usage: deepseek [--flash|--pro] <prompt>", file=sys.stderr)
        sys.exit(1)

    model = MODELS.get(model_key, model_key)
    result = call_deepseek(prompt, model)
    print(result)


def call_deepseek(prompt: str, model: str) -> str:
    payload = {
        "model": model,
        "max_tokens": 16000,
        "messages": [{"role": "user", "content": prompt}],
    }
    req = urllib.request.Request(
        f"{BASE_URL}/v1/messages",
        data=json.dumps(payload).encode(),
        method="POST",
        headers={
            "x-api-key": API_KEY,
            "anthropic-version": "2023-06-01",
            "content-type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=300) as resp:
            data = json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        return f"[DeepSeek API error: {e.code} {e.reason}]"
    except Exception as e:
        return f"[DeepSeek error: {e}]"

    for block in data.get("content", []):
        if block.get("type") == "text":
            return block["text"]
    return "[no text in response]"


if __name__ == "__main__":
    main()
