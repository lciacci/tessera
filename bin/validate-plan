#!/usr/bin/env python3
"""Multi-model plan validator — sends plan to reviewers, counts approvals.

Usage:
  validate-plan ~/.claude/plans/some-plan.md
  validate-plan --threshold 2 ~/.claude/plans/some-plan.md
  cat plan.txt | validate-plan --brief

Returns JSON with approval status. Exit 0 if approved (2+ of 3 agree).
"""

# Runs on ANY python3 — including macOS's /usr/bin/python3 (3.9), which a PATH can hand
# you at any time. `#!/usr/bin/env python3` resolves a NAME, and the name's VERSION drifts
# with it. PEP-604 annotations (`str | None`) raise TypeError at definition time on 3.9.
# `from __future__ import annotations` makes them lazy strings. Do not remove.
from __future__ import annotations

import json
import os
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path

REVIEWERS = {
    "deepseek": {
        "cmd": [os.path.expanduser("~/bin/deepseek"), "--pro"],
        "label": "DeepSeek Pro",
    },
    "codex": {
        "cmd": ["codex", "exec"],
        "label": "Codex",
    },
    "gemini": {
        "cmd": [os.path.expanduser("~/bin/gemini"), "--pro"],
        "label": "Gemini Pro",
    },
}

REVIEW_PROMPT = """Review this implementation plan. Evaluate:
1. Is the approach sound and complete?
2. Are there missing edge cases or risks?
3. Is the scope appropriate (not over/under-engineered)?
4. Can this be executed safely without human intervention?

Reply with exactly:
APPROVED: <one-sentence reason>
or
CHANGES_NEEDED: <one-sentence reason with specific changes>

Plan:
"""


def run_reviewer(name: str, config: dict, plan: str) -> dict:
    prompt = REVIEW_PROMPT + plan[:8000]
    try:
        result = subprocess.run(
            config["cmd"] + [prompt],
            capture_output=True, text=True, timeout=120,
        )
        output = result.stdout.strip() if result.returncode == 0 else result.stderr.strip()
        approved = "APPROVED" in output.upper()[:20]
        return {
            "reviewer": name,
            "label": config["label"],
            "approved": approved,
            "output": output[:500],
        }
    except Exception as e:
        return {"reviewer": name, "label": config["label"], "approved": False, "output": str(e)[:200]}


def main():
    threshold = 2  # need 2+ approvals
    plan = None

    args = sys.argv[1:]
    i = 0
    while i < len(args):
        if args[i] == "--threshold" and i + 1 < len(args):
            threshold = int(args[i + 1])
            i += 2
        elif args[i] == "--brief":
            threshold = 1
            i += 1
        elif not args[i].startswith("-"):
            plan_path = Path(args[i]).expanduser()
            if plan_path.exists():
                plan = plan_path.read_text()
            i += 1
        else:
            i += 1

    if not plan and not sys.stdin.isatty():
        plan = sys.stdin.read().strip()

    if not plan:
        print(json.dumps({"error": "no plan provided"}, indent=2))
        sys.exit(1)

    print(f"[validate-plan] {len(REVIEWERS)} reviewers, threshold={threshold}", file=sys.stderr)

    results = {}
    with ThreadPoolExecutor(max_workers=len(REVIEWERS)) as executor:
        futures = {
            executor.submit(run_reviewer, name, config, plan): name
            for name, config in REVIEWERS.items()
        }
        for future in as_completed(futures):
            r = future.result()
            results[r["reviewer"]] = r
            status = "APPROVED" if r["approved"] else "CHANGES_NEEDED"
            print(f"[validate-plan] {r['label']}: {status}", file=sys.stderr)

    approvals = sum(1 for r in results.values() if r["approved"])
    total = len(results)
    verdict = "APPROVED" if approvals >= threshold else "CHANGES_NEEDED"

    output = {
        "verdict": verdict,
        "approvals": f"{approvals}/{total}",
        "threshold": threshold,
        "reviews": {
            name: {
                "label": r["label"],
                "approved": r["approved"],
                "reason": r["output"][:300],
            }
            for name, r in results.items()
        },
    }

    print(json.dumps(output, indent=2))

    if verdict == "APPROVED":
        sys.exit(0)
    else:
        sys.exit(1)


if __name__ == "__main__":
    main()
