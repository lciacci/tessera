#!/usr/bin/env python3
"""Multi-model review orchestrator — runs reviews in parallel across backends.

Usage:
  review "code or design to review"
  review --file path/to/file.py
  review --deepseek --kimi "prompt"        # Specific backends only
  echo "code" | review --all               # Pipe mode

Default backends: deepseek-pro + kimi (codex optional, needs OPENAI_API_KEY)
"""

# Runs on ANY python3 — including macOS's /usr/bin/python3 (3.9), which a PATH can hand
# you at any time. `#!/usr/bin/env python3` resolves a NAME, and the name's VERSION drifts
# with it. PEP-604 annotations (`str | None`) raise TypeError at definition time on 3.9.
# `from __future__ import annotations` makes them lazy strings. Do not remove.
from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime, timezone

# RESOLVE BY NAME, ON PATH — never by a hardcoded absolute path. These read
# `~/bin/deepseek` and `~/bin/kimi` until 2026-07-13; `~/bin/` does not exist, while the
# working wrappers sit in `tessera/bin/` on PATH. Every reviewer therefore raised
# FileNotFoundError and was rendered as a reviewer that ran and FAILED — rather than one
# that was never installed. Same root cause as bin/validate-plan; see scripts/test_council.py.
REVIEWERS = {
    "deepseek": {
        "cmd": ["deepseek", "--pro"],
        "label": "DeepSeek Pro",
        "cost_est": 0.0004,
        "enabled": True,
    },
    "kimi": {
        "cmd": ["kimi", "--quiet", "-p"],
        "label": "Kimi K2.6",
        "cost_est": 0.0006,
        "enabled": True,
    },
    "codex": {
        "cmd": ["codex", "exec"],
        "label": "Codex",
        "cost_est": 0.02,
        "enabled": bool(os.environ.get("OPENAI_API_KEY")),
    },
}


def run_reviewer(name: str, config: dict, prompt: str) -> dict:
    """Run a single reviewer and return structured result."""
    try:
        cmd = config["cmd"] + [prompt]
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=120,
        )
        success = result.returncode == 0 and bool(result.stdout.strip())
        return {
            "reviewer": name,
            "label": config["label"],
            "success": success,
            "output": result.stdout.strip() if success else result.stderr.strip()[:500],
            "cost_est": config["cost_est"],
        }
    except subprocess.TimeoutExpired:
        return {"reviewer": name, "label": config["label"], "success": False, "output": "Timeout (120s)", "cost_est": 0}
    except Exception as e:
        return {"reviewer": name, "label": config["label"], "success": False, "output": str(e)[:200], "cost_est": 0}


def main():
    args = sys.argv[1:]
    specific_backends = []
    prompt = None

    for arg in args:
        if arg in ("--deepseek", "-d"):
            specific_backends.append("deepseek")
        elif arg in ("--kimi", "-k"):
            specific_backends.append("kimi")
        elif arg in ("--codex", "-c"):
            specific_backends.append("codex")
        elif arg in ("--all", "-a"):
            specific_backends = ["deepseek", "kimi", "codex"]
        elif arg.startswith("--file"):
            continue
        elif arg == "-f":
            continue
        else:
            prompt = arg

    if not prompt and not sys.stdin.isatty():
        prompt = sys.stdin.read().strip()

    if not prompt:
        print("Usage: review [--deepseek] [--kimi] [--codex] [--all] <prompt>", file=sys.stderr)
        sys.exit(1)

    # Determine active reviewers. A backend that is NOT INSTALLED is excluded and named —
    # it must never be rendered as a reviewer that ran and FAILED. Silence is not a finding.
    active = specific_backends or ["deepseek", "kimi"]
    requested = {k: v for k, v in REVIEWERS.items() if k in active and v["enabled"]}
    reviewers = {k: v for k, v in requested.items() if shutil.which(v["cmd"][0])}
    unavailable = [k for k in requested if k not in reviewers]

    if unavailable:
        print(f"[review] UNAVAILABLE (not installed, excluded): {', '.join(unavailable)}",
              file=sys.stderr)

    if not reviewers:
        print("[review] FATAL: no reviewers available — nothing was reviewed.", file=sys.stderr)
        sys.exit(2)

    ts = datetime.now(timezone.utc).isoformat()
    print(f"[review] Running {len(reviewers)} reviewers in parallel...", file=sys.stderr)
    for name in reviewers:
        print(f"  {reviewers[name]['label']}", file=sys.stderr)

    # Run all reviewers in parallel
    results = {}
    with ThreadPoolExecutor(max_workers=len(reviewers)) as executor:
        futures = {
            executor.submit(run_reviewer, name, config, prompt): name
            for name, config in reviewers.items()
        }
        for future in as_completed(futures):
            result = future.result()
            results[result["reviewer"]] = result

    total_cost = sum(r["cost_est"] for r in results.values())

    # Output results
    print(f"\n{'='*60}")
    print(f"Multi-Model Review — {len(results)} reviewers, est. cost ${total_cost:.4f}")
    print(f"{'='*60}\n")

    for name in ["deepseek", "kimi", "codex"]:
        if name not in results:
            continue
        r = results[name]
        status = "PASS" if r["success"] else "FAIL"
        print(f"## {r['label']} ({status})\n")
        print(r["output"][:3000])
        print(f"\n---\n")

    # Log to eval
    log_file = os.path.expanduser("~/.claude/review-log.jsonl")
    os.makedirs(os.path.dirname(log_file), exist_ok=True)
    with open(log_file, "a") as f:
        f.write(json.dumps({
            "ts": ts,
            "prompt": prompt[:200],
            "reviewers": list(results.keys()),
            "total_cost": total_cost,
        }) + "\n")


if __name__ == "__main__":
    main()
