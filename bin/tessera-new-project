#!/usr/bin/env bash
# Stand up a new downstream Tessera project with the harness layer.
#
#   tessera-new-project [--frozen] <target-dir> [project-name] [profile]
#
# Hook distribution (ADR-0004): default is `global` — no local mnemos script
# copies; hooks resolve from ~/.claude/templates (single source, zero drift).
# Pass --frozen for ship-critical projects that want pinned, churn-immune local
# copies. Flip later with `tessera-hooks freeze|thaw`.
#
# Lays down: .claude/ (mnemos hooks + settings), scripts/gate (recorder),
# .tessera/ (profile + logs), CLAUDE.md, .gitignore, and `git init`. Harness
# scripts are copied from THIS tessera checkout's live source — single source of
# truth, not a stale template copy. App/stack scaffold is NOT done here: generate
# that with your platform's own tool (Android Studio, create-vite, etc.) and let
# this harness coexist on top.
set -euo pipefail

TESSERA_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TPL="$TESSERA_ROOT/templates/tessera"

DISTRO=global
if [ "${1:-}" = "--frozen" ]; then DISTRO=frozen; shift; fi

TARGET="${1:?usage: tessera-new-project [--frozen] <target-dir> [project-name] [profile]}"
NAME="${2:-$(basename "$TARGET")}"
PROFILE="${3:-standard}"

[ -e "$TARGET" ] && { echo "refuse: $TARGET already exists" >&2; exit 1; }
for f in "$TPL/CLAUDE.md.template" "$TPL/settings.base.json" "$TPL/gitignore.base" \
         "$TPL/project.yml.template" "$TPL/security-exceptions.yml.template" \
         "$TPL/config.yml.template"; do
  [ -f "$f" ] || { echo "missing template: $f" >&2; exit 1; }
done

mkdir -p "$TARGET/.claude/scripts" "$TARGET/.tessera/logs" "$TARGET/.mnemos" \
         "$TARGET/scripts/gate" "$TARGET/scripts/spend"

# Harness scripts. Default (global): no local mnemos copies — settings.json falls
# back to ~/.claude/templates. Frozen: pin live copies now (anti-drift snapshot).
if [ "$DISTRO" = frozen ]; then
  cp "$TESSERA_ROOT"/.claude/scripts/mnemos-*.sh "$TARGET/.claude/scripts/"
  chmod +x "$TARGET"/.claude/scripts/*.sh
fi
# Gate recorder is always project-local (not a global-fallback hook). Its Stop-hook
# backstop rides along: the recorder alone rides model recall and under-logs badly
# (~85%, observatory), so shipping it without the scan ships the broken half.
cp "$TESSERA_ROOT"/scripts/gate/emit.py "$TESSERA_ROOT"/scripts/gate/test_gate_emit.py \
   "$TESSERA_ROOT"/scripts/gate/scan.py "$TESSERA_ROOT"/scripts/gate/test_gate_scan.py \
   "$TARGET/scripts/gate/"
cp "$TESSERA_ROOT"/.claude/scripts/tessera-gate-scan.sh "$TARGET/.claude/scripts/"
chmod +x "$TARGET/.claude/scripts/tessera-gate-scan.sh"
# Escalation: reached by name from PATH (tessera/bin). The copy is a BRIDGE for machines
# where PATH is not set — delete it once install.sh's PATH check is green everywhere.
cp "$TESSERA_ROOT"/bin/tessera-escalate "$TARGET/scripts/tessera-escalate"
chmod +x "$TARGET/scripts/tessera-escalate"

# Spend guard (spec 06). The hook wrapper FAILS OPEN when guard.py is absent — so shipping
# tessera-spend-guard.sh without scripts/spend/ ships a hook that silently protects nothing
# and still looks wired. Same shape as the gate recorder above: ship both halves or neither.
# The backstop rides along, same rule as the gate recorder: the guard's deny path ends in a
# PROSE instruction ("raise a packet"), which is model recall — the exact trigger that missed
# ~85% of gates. Shipping the guard without its backstop ships the broken half.
cp "$TESSERA_ROOT"/scripts/spend/guard.py "$TESSERA_ROOT"/scripts/spend/event.py \
   "$TESSERA_ROOT"/scripts/spend/authorize.py "$TESSERA_ROOT"/scripts/spend/backstop.py \
   "$TESSERA_ROOT"/scripts/spend/conftest.py "$TESSERA_ROOT"/scripts/spend/test_guard.py \
   "$TESSERA_ROOT"/scripts/spend/test_backstop.py \
   "$TARGET/scripts/spend/"
cp "$TESSERA_ROOT"/.claude/scripts/tessera-spend-guard.sh \
   "$TESSERA_ROOT"/.claude/scripts/tessera-spend-backstop.sh "$TARGET/.claude/scripts/"
chmod +x "$TARGET"/.claude/scripts/tessera-spend-guard.sh \
         "$TARGET"/.claude/scripts/tessera-spend-backstop.sh "$TARGET"/scripts/spend/guard.py

# Settings + gitignore (stack-agnostic bases — add your stack's commands after).
cp "$TPL/settings.base.json" "$TARGET/.claude/settings.json"
cp "$TPL/gitignore.base" "$TARGET/.gitignore"

# .tessera/ config.
sed -e "s|^profile: .*|profile: $PROFILE|" -e "s|^hook_distro: .*|hook_distro: $DISTRO|" \
    "$TPL/project.yml.template" > "$TARGET/.tessera/project.yml"
cp "$TPL/security-exceptions.yml.template" "$TARGET/.tessera/security-exceptions.yml"
# config.yml is COMMITTED, not gitignored: `test:` must survive a fresh clone or the agent
# that needs it most — an unsupervised one — has nothing to read. Ships with test: blank.
cp "$TPL/config.yml.template" "$TARGET/.tessera/config.yml"
printf '*\n' > "$TARGET/.mnemos/.gitignore"
cat > "$TARGET/.tessera/logs/README.md" <<'EOF'
# Tessera Event Logs

Structured event logs from Tessera sessions live here as `<session-id>.jsonl`.
The suggestion-gate recorder (`scripts/gate/emit.py`) appends `suggestion_gate`
events here. This directory is gitignored — logs are session-local.
EOF

# CLAUDE.md — fill scalar placeholders; description/commands left for the owner.
sed -e "s|{{PROJECT_NAME}}|$NAME|g" -e "s|{{PROFILE}}|$PROFILE|g" \
    "$TPL/CLAUDE.md.template" > "$TARGET/CLAUDE.md"

( cd "$TARGET" && git init -q && git symbolic-ref HEAD refs/heads/main )

# iCPG: init the intent graph so SessionStart's bridge-icpg can feed Mnemos's
# code-intent Goal/ConstraintNodes. Bootstrap is skipped here (fresh repo, no
# history yet) — run `icpg bootstrap` after the first commits land. Guarded so a
# missing icpg CLI doesn't abort the scaffold (set -e).
if command -v icpg >/dev/null 2>&1; then
  ( cd "$TARGET" && icpg init >/dev/null 2>&1 ) || true
fi

echo "scaffolded '$NAME' at $TARGET (profile: $PROFILE, hooks: $DISTRO)"
[ "$DISTRO" = global ] && echo "  hooks ride ~/.claude/templates — run install.sh on this machine if not yet done"
echo "next:"
echo "  - fill {{PROJECT_DESCRIPTION}} and {{COMMANDS}} in CLAUDE.md"
echo "  - add your stack's build/test commands to .claude/settings.json allow[] (remove _stack_allow_note)"
echo "  - generate the app skeleton with your platform's tool, then commit"
echo "  - after first commits: run 'icpg bootstrap' to seed code-intent goals (bridges into Mnemos on next session)"
