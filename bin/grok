#!/usr/bin/env python3
"""Grok (xAI) delegation script — OpenAI-compatible API.

Usage:
  grok "prompt"                         # Default: grok-4.3
  echo "prompt" | grok                  # Pipe mode

Env: XAI_API_KEY required.
"""

# Runs on ANY python3 — including macOS's /usr/bin/python3 (3.9), which a PATH can hand
# you at any time. `#!/usr/bin/env python3` resolves a NAME, and the name's VERSION drifts
# with it. PEP-604 annotations (`str | None`) raise TypeError at definition time on 3.9.
# `from __future__ import annotations` makes them lazy strings. Do not remove.
from __future__ import annotations

import json
import os
import sys
import urllib.error
import urllib.request

# STDLIB ONLY — on purpose, and enforced by doccheck `bin-scripts-are-stdlib-only`.
#
# This file used to `import httpx`. httpx is installed NOWHERE on this machine — not in the
# venv, not in any Homebrew python — so `grok` had never run, ever, on any interpreter.
# It failed with ModuleNotFoundError, `bin/validate-plan` caught that and scored it as a
# reviewer VOTING NO, and Tessera's council reported a confident `CHANGES_NEEDED 0/3` built
# entirely out of this. (2026-07-13, FOCUS-004.)
#
# The fix is NOT to add httpx to the venv. `bin/` is reached through a bare interpreter NAME,
# and a name resolves through a PATH four package managers write to — so bin/ must import only
# what the oldest interpreter that PATH can hand it already has. urllib does this POST fine.
API_KEY = os.environ.get("XAI_API_KEY", "")
BASE_URL = "https://api.x.ai/v1"


def main():
    prompt = None

    args = sys.argv[1:]
    for arg in args:
        if not arg.startswith("-"):
            prompt = arg
            break

    if not API_KEY:
        print("[grok] ERROR: XAI_API_KEY not set", file=sys.stderr)
        print("  Add to ~/.zshrc: export XAI_API_KEY=\"xai-...\"", file=sys.stderr)
        sys.exit(1)

    if not prompt and not sys.stdin.isatty():
        prompt = sys.stdin.read().strip()

    if not prompt:
        print("Usage: grok <prompt>", file=sys.stderr)
        sys.exit(1)

    result = call_grok(prompt)
    print(result)


def call_grok(prompt: str) -> str:
    payload = {
        "model": "grok-4.3",
        "messages": [{"role": "user", "content": prompt}],
        "max_tokens": 16000,
    }
    req = urllib.request.Request(
        f"{BASE_URL}/chat/completions",
        data=json.dumps(payload).encode(),
        method="POST",
        headers={
            "Authorization": f"Bearer {API_KEY}",
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=120) as resp:
            data = json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        return f"[Grok API error: {e.code} {e.reason}]"
    except Exception as e:
        return f"[Grok error: {e}]"

    choices = data.get("choices", [])
    if choices:
        content = choices[0].get("message", {}).get("content", "")
        return content or "[grok: no content in response]"
    return "[grok: no choices in response]"


if __name__ == "__main__":
    main()
