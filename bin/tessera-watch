#!/usr/bin/env python3
"""tessera-watch — evaluate the Observatory's silent+machine-checkable triggers.

The Observatory's "When to revisit" conditions are prose: they fire only when a
human happens to re-read them, and on 2026-07-09 three sat past threshold
unnoticed (docs/observatory.md → "The Observatory's own triggers are prose").
This converts the five silent-AND-checkable triggers into predicates that check
themselves, surfaced via a SessionStart hook — a non-model channel, principle #17.

Substrate-only pilot (roadmap Tier 1 / spec 03 de-risk): a flat predicate list,
NO snooze/hysteresis/prose-parsing until a graduation predicate earns it. The
fired set is appended (with --log) to .tessera/logs/watch.jsonl — the fire-log
that also feeds the kill and graduate decisions. See _project_specs/todos/active.md.

    tessera-watch            # print fired predicates; exit 1 if any fire, else 0
    tessera-watch --json     # machine output
    tessera-watch --log      # append the run to the fire-log (the SessionStart hook passes this)
"""

# Runs on ANY python3 — including macOS's /usr/bin/python3 (3.9), which a PATH can hand
# you at any time. `#!/usr/bin/env python3` resolves a NAME, and the name's VERSION drifts
# with it. PEP-604 annotations (`str | None`) raise TypeError at definition time on 3.9.
# `from __future__ import annotations` makes them lazy strings. Do not remove.
from __future__ import annotations
import argparse
import json
import shutil
import sqlite3
import subprocess
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent

COMPACTION_MIN = 3      # mnemos trial: judge after ≥3 compaction_fired events
DOWNSTREAM_MIN = 5      # F-003: hook-drift risk as downstream count crosses ~4–5
SKILL_MIN = 60          # two-stage skill routing earns its keep at 60+ skills
GRADUATION_RUNS = 3     # a core predicate firing this many runs running → graduation-a
GATE_LABEL_MIN = 20     # unlabeled post-backstop gates before should_fire labeling earns its slot
BACKSTOP_LIVE = "2026-07-12"  # gate-scan wired everywhere; events from here are an honest sample
HAZE_RECALIB_MIN = 40   # real-signal sessions before revisiting haziness bands (24 at spec-13 backfill; ~16 runway) (2026-07-17)
INGEST_STALE_MIN_AGE_H = 1     # transcripts younger than this may be a live session — not yet a miss
INGEST_STALE_MAX_AGE_D = 7     # older than this is history, not a live pipe problem
INGEST_MIN_BYTES = 10_000      # skip 2-turn husk transcripts
FALLBACK_STREAK = 3            # consecutive regex-only ingests before surfacing


def p1_hook_drift(root: Path) -> tuple[bool, str]:
    """Live SessionStart/etc. hooks missing from or differing in the install payload."""
    drift = []
    for s in sorted((root / ".claude" / "scripts").glob("*.sh")):
        t = root / "templates" / s.name
        if not t.exists() or t.read_bytes() != s.read_bytes():
            drift.append(s.name)
    if not drift:
        return False, "hooks in sync with templates/"
    return True, f"{len(drift)} live hook(s) missing/differ in templates/: {', '.join(drift)}"


# P2 (tess-verb count → `tess` umbrella) was RETIRED 2026-07-10. It fired on a
# proxy — verb count — that tracks no real friction: the tessera-* binaries are
# mostly hook-invoked, and an umbrella can't retire them (hooks call them by name),
# so it would add a layer, not consolidate. See observatory "Override mechanism".


def p3_compaction(root: Path) -> tuple[bool, str]:
    """Real (auto) compaction_fired count — the Mnemos kill/keep trial's event trigger.

    Excludes `trigger: manual` — a hand-run `/compact` is a *test* of the recovery layer,
    not evidence about it. Counting tests as evidence would let three deliberate test
    compactions deliver the trial's verdict on manufactured data: the P2 failure exactly
    (a predicate firing correctly on a proxy that tracks no real pain).

    A MISSING trigger key is counted as real — pre-2026-07-11 entries predate the tagging, and
    any compaction from back then was necessarily an auto one.

    ── `trigger: "unknown"` IS NOT THE SAME AS A MISSING KEY. Fixed 2026-07-12. ─────────────

    The PreCompact hook defaults to the literal string `"unknown"` and overwrites it only if it
    can read `.trigger` off stdin. So `"unknown"` means **the tagger ran and could not classify
    the event** — a measurement failure, not a measurement.

    This predicate lumped it into `else: real += 1`. So an event we cannot classify was silently
    promoted to **evidence for a kill/keep trial** — which is the exact contamination the whole
    trigger-tagging fix was built to prevent, arriving through the one door nobody watched.

    It was live: a compaction fired on 2026-07-12 with `trigger: "unknown"`, and P3 read it as
    `1 real`. The hook itself is fine (fed `manual` and `auto` on stdin, it records both
    correctly) — Claude Code simply sent no trigger field for that event, and it is not
    reconstructable after the fact.

    So: **unknown is excluded from BOTH counts and reported LOUDLY.** A verdict must never rest
    on an event whose provenance the instrument could not read, and an instrument that cannot
    read should say so rather than guess. (docs/observatory.md → "Fail-open everywhere".)
    """
    log = root / ".mnemos" / "compaction-log.jsonl"
    real = manual = unknown = 0
    if log.exists():
        for line in log.read_text().splitlines():
            try:
                event = json.loads(line)
            except ValueError:
                continue
            if event.get("event") != "compaction_fired":
                continue
            trigger = event.get("trigger", "__absent__")
            if trigger == "manual":
                manual += 1
            elif trigger == "unknown":
                unknown += 1          # the tagger failed. Not evidence, not a test. Unusable.
            else:
                real += 1             # "auto", or a pre-tagging entry with no key at all
    notes = []
    if manual:
        notes.append(f"{manual} manual test(s) excluded")
    if unknown:
        notes.append(f"⚠️ {unknown} UNCLASSIFIABLE (trigger unreadable — NOT counted as evidence)")
    note = f" ({'; '.join(notes)})" if notes else ""
    return real >= COMPACTION_MIN, (f"{real} real compaction_fired{note} "
                                    f"(≥{COMPACTION_MIN} → judge the Mnemos trial)")


def p4_downstream(root: Path) -> tuple[bool, str]:
    """Downstream projects (declare .tessera/project.yml), excluding the framework itself."""
    n = len(_downstream_projects(root))
    return n >= DOWNSTREAM_MIN, f"{n} downstream projects (≥{DOWNSTREAM_MIN} → F-003 hook-drift risk)"


def p5_skills(root: Path) -> tuple[bool, str]:
    """Skill count — eager-listing token cost the two-stage router would cut."""
    n = sum(1 for d in (root / ".claude" / "skills").iterdir() if d.is_dir())
    return n >= SKILL_MIN, f"{n} skills (≥{SKILL_MIN} → two-stage hierarchical routing)"


def p6_escalations(root: Path) -> tuple[bool, str]:
    """Open escalation packets — an agent stopped, blocked, and needs a human decision.

    Surfacing rides the watcher rather than a fourth SessionStart hook. If this stays
    fired for 3 runs, G-a fires too — and that is correct, not noise: an escalation
    ignored for three sessions is a real finding about the human, not a bad predicate.
    Contract: docs/contracts/escalation.md.
    """
    directory = root / ".tessera" / "escalations"
    if not directory.is_dir():
        return False, "0 open escalations"
    open_count = 0
    for path in directory.glob("*.json"):
        try:
            packet = json.loads(path.read_text())
        except (OSError, json.JSONDecodeError):
            open_count += 1  # unreadable packet counts as needs-attention, never dropped
            continue
        if (packet.get("status") or "open").split(":", 1)[0].strip() == "open":
            open_count += 1
    return open_count > 0, f"{open_count} open escalations (→ `tessera-escalate list`)"


def p7_gate_labels(root: Path) -> tuple[bool, str]:
    """Unlabeled gate events recorded AFTER the gate-scan backstop went live.

    `should_fire` is the gate contract's ground-truth column and is null on every event
    ever recorded. Labeling was deferred 2026-07-11 (ADR-0005) for two reasons: the
    pre-backstop corpus is 61–91% truncated, and v1 escalation fires on hard blocks only,
    so no threshold depends on it yet. Neither reason survives a corpus that is both
    honest and large — so the revisit is a predicate, not a note. A note is what gets
    dropped on the floor; that is the drift this watcher exists to catch.

    Counts tessera + every downstream, since autonomy runs the downstreams.
    """
    total = 0
    for project in [root, *_downstream_projects(root)]:
        for log in (project / ".tessera" / "logs").glob("*.jsonl"):
            for line in log.read_text().splitlines():
                try:
                    event = json.loads(line)
                except ValueError:
                    continue
                if event.get("type") != "suggestion_gate":
                    continue
                if event.get("ts", "") < BACKSTOP_LIVE:
                    continue  # pre-backstop = truncated sample, not worth labeling
                if (event.get("data") or {}).get("should_fire") is None:
                    total += 1
    fired = total >= GATE_LABEL_MIN
    return fired, (f"{total} unlabeled post-backstop gates "
                   f"(≥{GATE_LABEL_MIN} → corpus is honest + big enough; label should_fire)")


def p8_doc_drift(root: Path) -> tuple[bool, str]:
    """Docs asserting things about this repo that are no longer true.

    Six doc-drift bugs were found 2026-07-09..11 — every one by Lorenzo asking "all docs
    updated?" on a hunch, and every one fixed without leaving a check behind. The human was
    the detector, and suspicion is a depleting resource: the better the framework gets, the
    less it gets asked, so drift accumulates fastest exactly when trust is highest. **Trust
    was the failure mode.** That is a #17 failure one level up — the *verification* rode on
    recall, not a channel. This is the channel. See scripts/doccheck.py.
    """
    sys.path.insert(0, str(root / "scripts"))
    try:
        import doccheck
        doccheck.ROOT = root
        violations = [v for vs in doccheck.run().values() for v in vs]
    except Exception:
        return False, "doccheck unavailable (failing open)"
    if not violations:
        return False, f"docs honest ({len(doccheck.CHECKS)} checks, 0 false claims)"
    head = violations[0] if len(violations) == 1 else f"{violations[0]} (+{len(violations)-1} more)"
    return True, f"{len(violations)} false doc claim(s) → `python3 scripts/doccheck.py`: {head}"


def p9_interpreter_drift(root: Path) -> tuple[bool, str]:
    """Bare `python3` cannot import the toolchain the hooks depend on.

    THIS IS THE F-001 DETECTOR, three months late. F-001 was: hooks invoked Mnemos via bare
    `python3` (Homebrew 3.14) while the package was installed for 3.13, so `auto_nodes` and
    every checkpoint write silently no-op'd for weeks. It was invisible — and it confounded
    the entire Mnemos kill/keep trial, because "the graph is empty" read as "unused" when it
    actually meant "unreachable". Nothing has ever watched for a recurrence.

    The condition is live RIGHT NOW: python@3.14 owns the `python3` name (Homebrew installed
    it as a dependency of awscli/httpie/mlx/ollama — `installed_on_request: False`, so it is
    NOT removable), while the whole toolchain lives in 3.13. Nothing is broken today, because
    mnemos's console-script shebang hard-pins 3.13 and the hooks probe `command -v mnemos`
    first. But every bare-`python3` script that grows a third-party import is a landmine, and
    it fails SILENTLY — the worst shape for an unsupervised run (ADR-0005).

    Deprecating 3.14 is impossible (five formulae need it). Migrating the toolchain INTO 3.14
    only resets the clock — Homebrew re-points `python3` whenever a dependent formula moves,
    so 3.15 will do this again. **A venv is the durable fix**, and docs/observatory.md said so
    long before this predicate existed. Decided 2026-07-11 (1a/2b): venv is right, deferred.

    So this fires every session until the venv lands. That is intentional, not noise — it is
    real, unresolved debt, and after 3 consecutive runs G-a escalates it. A prose note is what
    gets dropped on the floor; that is the entire lesson of this watcher.

    ── REWRITTEN 2026-07-12, when the venv landed. The old predicate was:

            subprocess.run(["python3", "-c", "import mnemos"])   # fires unless bare python3
                                                                 # can import the toolchain

    **That predicate could never go green after the fix it was demanding.** A venv does not
    change what bare `python3` resolves to; post-venv it *should* be unable to import mnemos,
    and that is correct, not broken. P9 would have fired forever, G-a would have escalated
    forever, and the only way out would have been to snooze our own detector — the inverse of
    the pre-commit lesson: **a detector that cannot go green teaches you to ignore the
    watcher.** It was asserting the wrong invariant all along; it just happened to be red for
    the right reason.

    The invariant that actually matters is the one F-001 violated:
    **does the interpreter the CONSUMER resolves actually have what it imports?**
    F-001 was never "bare python3 lacks mnemos" — it was "the hooks' interpreter lacked
    mnemos, and nobody checked *which* interpreter the hooks got."

    So: resolve `mnemos` the way a hook does (`command -v`), read the shebang it will actually
    execute under, and assert THAT interpreter can import the toolchain — and that its base is
    not owned by a package manager free to re-point it.
    """
    venv_python = root / ".venv" / "bin" / "python"
    expects_venv = (root / ".python-version").exists()

    mnemos_bin = shutil.which("mnemos")
    if not mnemos_bin:
        # "Nothing to drift from" was the old escape hatch, and it was a HOLE: with the venv
        # missing, ~/.local/bin/mnemos dangles, `which` returns None, and the detector went
        # SILENT on the worst possible state — the toolchain gone entirely, every hook failing
        # open into quiet. Found 2026-07-12 by parking .venv and watching P9 say nothing.
        # Absence is the loudest drift there is, not the absence of drift.
        if expects_venv:
            return True, ("mnemos is NOT resolvable, but this repo declares a toolchain "
                          "(.python-version) — every hook is failing open into silence. "
                          "Run ./install.sh")
        return False, "mnemos CLI absent and no toolchain declared (nothing to drift from)"

    if expects_venv and not venv_python.exists():
        return True, (f"no venv at {venv_python} but .python-version declares one — "
                      f"the toolchain is unbuilt. Run ./install.sh")

    try:
        shebang = Path(mnemos_bin).read_text().splitlines()[0]
    except (OSError, IndexError):
        return True, f"cannot read mnemos's shebang at {mnemos_bin} — interpreter unknowable"
    if not shebang.startswith("#!"):
        return False, "mnemos is not a script (packaged binary?) — nothing to drift"
    interp = shebang[2:].split()[0]

    # THE check: the interpreter the hooks will actually run under must have the toolchain.
    probe = subprocess.run([interp, "-c", "import mnemos"], capture_output=True, timeout=10)
    if probe.returncode != 0:
        return True, (f"mnemos resolves {interp}, which CANNOT import mnemos — F-001 exactly: "
                      f"the hooks' interpreter is missing the package. Run ./install.sh")

    # And its base must not be a package manager's, or brew re-points it and we are back here.
    base = subprocess.run([interp, "-c", "import sys; print(sys.base_prefix)"],
                          capture_output=True, text=True, timeout=10).stdout.strip()
    if "homebrew" in base.lower() or "Cellar" in base:
        return True, (f"toolchain interpreter is rooted in Homebrew ({base}) — brew re-points "
                      f"python whenever a dependent formula moves. That is how F-001 happened. "
                      f"Rebuild on a uv-managed base: rm -rf .venv && ./install.sh")

    return False, f"toolchain interpreter is reachable and manager-independent ({interp})"


def g_a_consecutive(root: Path) -> tuple[bool, str]:
    """Graduation-a: a core predicate fired in ≥3 consecutive logged runs → needs snooze/ack.

    Closes the self-evaluation loop — the fire-log has a reader, so 'when to graduate
    to stateful machinery' is itself a fired predicate, not a prose note (#17). The
    detector is substrate; the remedy (actual snooze state) waits until this fires.
    """
    runs = _read_firelog(root)
    if len(runs) < GRADUATION_RUNS:
        return False, f"{len(runs)} logged runs (<{GRADUATION_RUNS} → not yet judgeable)"
    persistent = set.intersection(*(set(r) for r in runs[-GRADUATION_RUNS:]))
    # A currently-snoozed predicate is a remedy ALREADY APPLIED — G-a must not keep nagging
    # about it while the historical fire-log still shows it (the log is the tail, not now).
    snoozed = active_snooze_labels(root, datetime.now(timezone.utc))
    core = sorted(p for p in persistent if p.startswith("P") and p not in snoozed)
    if not core:
        return False, f"no core predicate fired {GRADUATION_RUNS} runs running"
    return True, f"{', '.join(core)} fired {GRADUATION_RUNS} consecutive runs → build remedy or add snooze"


def _read_firelog(root: Path) -> list[list[str]]:
    """Fired-label lists per prior run, chronological. The watcher reading its own history."""
    log = root / ".tessera" / "logs" / "watch.jsonl"
    if not log.exists():
        return []
    runs = []
    for line in log.read_text().splitlines():
        try:
            runs.append(json.loads(line).get("fired", []))
        except ValueError:
            pass
    return runs


def _count_event(log: Path, event: str) -> int:
    if not log.exists():
        return 0
    return sum(1 for line in log.read_text().splitlines() if _is_event(line, event))


def _is_event(line: str, event: str) -> bool:
    try:
        return json.loads(line).get("event") == event
    except (ValueError, AttributeError):
        return False


def _downstream_projects(root: Path) -> list[Path]:
    projects = (p.parent.parent for p in root.parent.glob("*/.tessera/project.yml"))
    return [p for p in projects if p.resolve() != root.resolve()]


# ── Snooze: an auditable ack that quiets a predicate for a bounded window. ──────────────
# EARNED by G-a (graduation-a): the observatory's "NO snooze until a graduation predicate
# earns it" is satisfied once G-a fires. A snooze is a DECISION, so it is TRACKED (committed
# .tessera/watch-snooze.json), carries a required --reason, and EXPIRES — a snoozed predicate
# resurfaces on the `until` date so nothing is buried forever. Snoozed-but-fired counts as
# NOT firing: quiet exit, and G-a stops counting it (the fire-log excludes it).
SNOOZE_PATH = ".tessera/watch-snooze.json"


def _load_snoozes(root: Path) -> dict:
    p = root / SNOOZE_PATH
    if not p.exists():
        return {}
    try:
        return json.loads(p.read_text())
    except ValueError:
        return {}


def _write_snoozes(root: Path, snoozes: dict) -> None:
    p = root / SNOOZE_PATH
    p.parent.mkdir(parents=True, exist_ok=True)
    p.write_text(json.dumps(snoozes, indent=2, sort_keys=True) + "\n")


def active_snooze_labels(root: Path, now: datetime) -> set:
    """Predicate labels with an unexpired snooze (now < until)."""
    active = set()
    for label, s in _load_snoozes(root).items():
        try:
            if now < datetime.fromisoformat(s["until"]):
                active.add(label)
        except (KeyError, ValueError, TypeError):
            continue
    return active


def p10_haze_recalib(root: Path) -> tuple[bool, str]:
    """Enough sessions carry REAL correction signal to re-tune the haziness bands.

    Spec 13 (2026-07-17) upgraded correction detection from a keyword regex (near-zero
    recall, every session read ~0) to a qwen3:8b classifier. Densities jumped from
    0.00–0.06 to a real 0.00–0.29 spread. The haziness bands (clear/cloudy/hazy/lost at
    0.25/0.50/0.75) and correction_density's 0.30 weight were tuned against the BLIND
    detector, so they want a re-look — but the classifier's precision is only ~0.5 on the one
    hand-labeled session, so re-tuning thresholds on it now would fit noise. Fires once a real
    sample has accumulated: the cue to spot-check precision on a FRESH sample first, then decide
    bands + weight. A predicate, not a note — a note gets dropped on the floor (should_fire, P7).
    """
    db = root / ".mnemos" / "mnemo.db"
    if not db.exists():
        return False, "no mnemos db"
    try:
        conn = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
        try:
            n = conn.execute(
                "SELECT count(*) FROM claude_haze WHERE correction_density > 0"
            ).fetchone()[0]
        finally:
            conn.close()
    except sqlite3.Error:
        return False, "no claude_haze table"
    return n >= HAZE_RECALIB_MIN, (
        f"{n} sessions with real correction signal "
        f"(≥{HAZE_RECALIB_MIN} → spot-check detector precision, then decide "
        f"haziness bands + 0.30 weight; spec 13)")


def _transcripts_dir(root: Path) -> Path:
    """Claude Code's per-project transcript dir for this repo (path-slug)."""
    slug = str(root.resolve()).replace("/", "-")
    return Path.home() / ".claude" / "projects" / slug


def p11_ingest_pipe(root: Path, transcripts_dir: Path | None = None) -> tuple[bool, str]:
    """The Stop-hook ingest pipe is silently dead or silently degraded.

    Two failure shapes, both observed or near-missed on 2026-07-20 (spec 16):
    (a) DEAD — ingest crashes before writing anything, so recent transcripts
        have no claude_sessions row at all. A status column cannot see this
        (nothing was written); only transcript-vs-store diffing can. This is
        exactly how a make_detector() import error killed every hook ingest
        from 07-17 to 07-20 while hand-runs kept working (F-001's cousin).
    (b) DEGRADED — ingest runs but the classifier silently falls back to
        regex-only every time (classifier_status trace, written per ingest).
    Age window: <1h may be a live session (not yet a miss); >7d is history.
    """
    tdir = transcripts_dir or _transcripts_dir(root)
    db = root / ".mnemos" / "mnemo.db"
    if not tdir.is_dir() or not db.exists():
        return False, "no transcripts dir or no mnemos db"
    now = datetime.now(timezone.utc).timestamp()
    recent = [p for p in tdir.glob("*.jsonl")
              if p.stat().st_size >= INGEST_MIN_BYTES
              and INGEST_STALE_MIN_AGE_H * 3600
                  <= now - p.stat().st_mtime
                  <= INGEST_STALE_MAX_AGE_D * 86400]
    try:
        conn = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
        try:
            known = {r[0] for r in conn.execute("SELECT id FROM claude_sessions")}
            cols = {r[1] for r in conn.execute("PRAGMA table_info(claude_sessions)")}
            streak = 0
            if "classifier_status" in cols:
                statuses = [r[0] for r in conn.execute(
                    "SELECT classifier_status FROM claude_sessions "
                    "WHERE classifier_status IS NOT NULL "
                    "ORDER BY last_ingested_at DESC LIMIT ?", (FALLBACK_STREAK,))]
                # budget-exhausted = classifier partially ran (a bulk sweep
                # sharing one wall-clock budget) — degraded is regex-only/
                # disabled, the shapes where it never judged a single turn.
                dead = ("regex-only:", "disabled-mid:")
                if len(statuses) == FALLBACK_STREAK and \
                        all(s.startswith(dead) for s in statuses):
                    streak = FALLBACK_STREAK
        finally:
            conn.close()
    except sqlite3.Error:
        return False, "no claude_sessions table"
    missing = sorted(p.stem[:8] for p in recent if p.stem not in known)
    if missing:
        return True, (
            f"{len(missing)} recent transcript(s) never ingested "
            f"({', '.join(missing[:5])}{'…' if len(missing) > 5 else ''}) — "
            f"Stop-hook ingest pipe looks DEAD; run it by hand and read stderr")
    if streak:
        return True, (
            f"last {streak} ingests all fell back to regex-only "
            f"(classifier_status) — classifier pipe silently degraded")
    return False, f"{len(recent)} recent transcript(s), all ingested; no fallback streak"


def _resolve_label(query: str) -> str | None:
    """Unique predicate whose label contains `query` (case-insensitive), or None."""
    matches = [label for label in PREDICATES if query.lower() in label.lower()]
    return matches[0] if len(matches) == 1 else None


PREDICATES = {
    "P1 hook-drift": p1_hook_drift,
    "P3 mnemos-trial": p3_compaction,
    "P4 downstream-drift": p4_downstream,
    "P5 skill-routing": p5_skills,
    "P6 escalations": p6_escalations,
    "P7 gate-labels": p7_gate_labels,
    "P8 doc-drift": p8_doc_drift,
    "P9 interpreter-drift": p9_interpreter_drift,
    "P10 haze-recalib": p10_haze_recalib,
    "P11 ingest-pipe": p11_ingest_pipe,
    "G-a graduation:snooze": g_a_consecutive,
}


def evaluate(root: Path) -> list[dict]:
    """Run every predicate; one result dict each. Mark any with an active snooze."""
    snoozed = active_snooze_labels(root, datetime.now(timezone.utc))
    snoozes = _load_snoozes(root)
    out = []
    for label, pred in PREDICATES.items():
        fired, detail = pred(root)
        s = snoozes.get(label, {}) if label in snoozed else {}
        out.append({"predicate": label, "fired": fired, "snoozed": label in snoozed,
                    "detail": detail, "snooze_until": s.get("until"),
                    "snooze_reason": s.get("reason")})
    return out


def append_log(root: Path, results: list[dict]) -> None:
    """Append this run's fired set to the fire-log (feeds kill + graduate decisions)."""
    log = root / ".tessera" / "logs" / "watch.jsonl"
    log.parent.mkdir(parents=True, exist_ok=True)
    entry = {
        "ts": datetime.now(timezone.utc).isoformat(),
        "fired": [r["predicate"] for r in results if r["fired"] and not r["snoozed"]],
    }
    with log.open("a") as f:
        f.write(json.dumps(entry) + "\n")


def render(results: list[dict]) -> str:
    fired = [r for r in results if r["fired"] and not r["snoozed"]]
    snoozed = [r for r in results if r["fired"] and r["snoozed"]]
    lines = []
    if fired:
        lines.append("Observatory triggers fired (docs/observatory.md — resolve or snooze):")
        lines += [f"  🔴 {r['predicate']}: {r['detail']}" for r in fired]
    for r in snoozed:
        lines.append(f"  💤 {r['predicate']}: snoozed until {(r['snooze_until'] or '?')[:10]}"
                     f" — {r['snooze_reason'] or ''}")
    return "\n".join(lines) if lines else "✓ no Observatory triggers fired"


def manage_snooze(root: Path, args, now: datetime) -> str:
    """Handle --snooze / --snooze-clear / --snooze-list. Returns a status line."""
    snoozes = _load_snoozes(root)
    if args.snooze_list:
        return "\n".join(f"  💤 {k}: until {v.get('until', '?')[:10]} — {v.get('reason', '')}"
                         for k, v in sorted(snoozes.items())) or "no active snoozes"
    if args.snooze_clear:
        label = _resolve_label(args.snooze_clear)
        if not label or label not in snoozes:
            return f"no snooze matching '{args.snooze_clear}'"
        del snoozes[label]
        _write_snoozes(root, snoozes)
        return f"cleared snooze on {label}"
    label = _resolve_label(args.snooze)
    if not label:
        return f"no unique predicate matches '{args.snooze}' — of: {', '.join(PREDICATES)}"
    if not args.reason:
        return "refusing to snooze without --reason (a snooze is an auditable decision)"
    until = (now + timedelta(days=args.days)).isoformat()
    snoozes[label] = {"until": until, "reason": args.reason, "snoozed_at": now.isoformat()}
    _write_snoozes(root, snoozes)
    return f"snoozed {label} until {until[:10]} ({args.days}d) — {args.reason}"


def main() -> int:
    ap = argparse.ArgumentParser(description="Evaluate Observatory silent+checkable triggers.")
    ap.add_argument("--json", action="store_true", help="machine output")
    ap.add_argument("--log", action="store_true", help="append run to .tessera/logs/watch.jsonl")
    ap.add_argument("--snooze", metavar="PREDICATE", help="ack+quiet a predicate (substring of its label)")
    ap.add_argument("--days", type=int, default=30, help="snooze window in days (with --snooze)")
    ap.add_argument("--reason", default="", help="why — required with --snooze (auditable)")
    ap.add_argument("--snooze-clear", metavar="PREDICATE", help="remove a snooze")
    ap.add_argument("--snooze-list", action="store_true", help="show active snoozes")
    args = ap.parse_args()

    if args.snooze or args.snooze_clear or args.snooze_list:
        print(manage_snooze(ROOT, args, datetime.now(timezone.utc)))
        return 0

    results = evaluate(ROOT)
    if args.log:
        append_log(ROOT, results)
    print(json.dumps(results, indent=2) if args.json else render(results))
    return 1 if any(r["fired"] and not r["snoozed"] for r in results) else 0


if __name__ == "__main__":
    raise SystemExit(main())
