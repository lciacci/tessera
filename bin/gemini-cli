#!/bin/bash
# Gemini CLI delegation — full coding agent with tools.
# Install: npm install -g @google/gemini-cli
# Auth: export GEMINI_API_KEY (uses same key as API)
#
# Usage:
#   gemini-cli "prompt"               # Default: auto model
#   gemini-cli --pro "prompt"         # Gemini 2.5/3 Pro
#   gemini-cli --flash "prompt"       # Gemini Flash (cheaper)
#   echo "code" | gemini-cli --pro    # Pipe mode

MODEL="auto"
PROMPT=""
for arg in "$@"; do
  case "$arg" in
    --pro|-p)    MODEL="pro" ;;
    --flash|-f)  MODEL="flash" ;;
    --flash-lite|-fl) MODEL="flash-lite" ;;
    --yolo|-y)   YOLO="--approval-mode=yolo" ;;
    *)           PROMPT="$arg" ;;
  esac
done

# Pipe mode
if [ -z "$PROMPT" ] && [ ! -t 0 ]; then
  PROMPT=$(cat 2>/dev/null || true)
fi

if [ -z "$PROMPT" ]; then
  echo "Usage: gemini-cli [--pro|--flash|--flash-lite] <prompt>" >&2
  exit 1
fi

if [ -z "$GEMINI_API_KEY" ]; then
  echo "[gemini-cli] WARNING: GEMINI_API_KEY not set — CLI may need separate auth" >&2
fi

# Find the actual Gemini CLI binary (not our ~/bin/gemini API delegator)
GEMINI_BIN=""
for candidate in \
  "$HOME/.nvm/versions/node/$(node -v 2>/dev/null | tr -d 'v')/bin/gemini" \
  "$(npm root -g 2>/dev/null)/.bin/gemini" \
  "/usr/local/bin/gemini" \
  "$(which -a gemini 2>/dev/null | grep -v "$HOME/bin" | head -1)"; do
  if [ -x "$candidate" ] && [ "$(dirname "$candidate")" != "$HOME/bin" ]; then
    GEMINI_BIN="$candidate"
    break
  fi
done

if [ -z "$GEMINI_BIN" ]; then
  echo "[gemini-cli] ERROR: Gemini CLI not found. Install: npm install -g @google/gemini-cli" >&2
  echo "[gemini-cli] Note: ~/bin/gemini is the API delegator, not the CLI." >&2
  exit 1
fi

exec "$GEMINI_BIN" -p "$PROMPT" -m "$MODEL" --output-format json --skip-trust ${YOLO:+"$YOLO"}
