#!/bin/bash
# PreToolUse hook (matcher: Task|Agent) — applies the Claude effort tier
# chosen by route-task-hook to spawned subagents.
#
# route-task-hook classifies each user prompt and caches the tier in
# ~/.claude/routing-cache.json. When a subagent is spawned, this hook reads
# that cache and, for CLAUDE_OPUS/SONNET/HAIKU tiers, rewrites the subagent's
# model via hookSpecificOutput.updatedInput — turning the advisory tier into
# real dispatch.
#
# Rules:
#   - Explicit model on the call always wins (we never override it).
#   - Only CLAUDE_* tiers map to a model; other tiers leave the default.
#   - permissionDecision is omitted so normal permission flow is unchanged.
#   - Fails open: any missing/stale/corrupt input => no override (exit 0).
# No set -euo pipefail: hook scripts must be defensive, not strict.

CACHE_FILE="$HOME/.claude/routing-cache.json"

INPUT=$(cat 2>/dev/null || true)
[ -z "$INPUT" ] && exit 0

# Respect an explicit model — if the spawn already set one, do nothing.
EXISTING=$(echo "$INPUT" | jq -r '.tool_input.model // empty' 2>/dev/null || echo "")
[ -n "$EXISTING" ] && exit 0

# Read the cached tier (written by route-task-hook on the last prompt).
[ -f "$CACHE_FILE" ] || exit 0
TIER=$(jq -r '.tier // empty' "$CACHE_FILE" 2>/dev/null || echo "")

# Map CLAUDE_<TIER> -> fable|opus|sonnet|haiku. Anything else: no override.
case "$TIER" in
  CLAUDE_FABLE)  MODEL="fable" ;;
  CLAUDE_OPUS)   MODEL="opus" ;;
  CLAUDE_SONNET) MODEL="sonnet" ;;
  CLAUDE_HAIKU)  MODEL="haiku" ;;
  *) exit 0 ;;
esac

# updatedInput REPLACES the tool input wholesale — it is not a patch. Emitting
# only {model} strips prompt/description and every spawn fails schema validation
# (found 2026-07-13: ALL Agent calls broken whenever a CLAUDE_* tier was cached
# and no explicit model set). Merge the override into the original input instead.
# Guard the degenerate shapes too: a null/non-object/empty tool_input would make
# `null + {model}` emit {model} alone — the same stripped-input bug through a side
# door (adversarially found 2026-07-13, first verify run refuted exactly this).
# `-n` + `input` consumes exactly ONE JSON document: a multi-document stdin
# otherwise makes jq emit once per document and the concatenation is malformed
# JSON (adversarially found; not a real harness payload, but free to close).
UPDATED=$(echo "$INPUT" | jq -cn --arg m "$MODEL" \
  'input | select((.tool_input | type) == "object" and (.tool_input | length) > 0) | .tool_input + {model: $m}' 2>/dev/null) || exit 0
[ -z "$UPDATED" ] && exit 0

cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "updatedInput": ${UPDATED}
  }
}
EOF
exit 0
