#!/bin/bash
# UserPromptSubmit hook — classifies each prompt via qwen3 and
# injects routing instructions into Claude's context.
#
# 6-tier routing: QWEN → DS_FLASH → DS_PRO → KIMI → CODEX → CLAUDE
# Exit 0 + additionalContext: Claude sees the routing tier.
# Falls back to cached tier when Ollama is unreachable (post-compact safety).
# No set -euo pipefail: hook scripts must be defensive, not strict.

INPUT=$(cat 2>/dev/null || true)
PROMPT=$(echo "$INPUT" | jq -r '.prompt // empty' 2>/dev/null || echo "")
CWD=$(echo "$INPUT" | jq -r '.cwd // empty' 2>/dev/null || echo ".")

CACHE_FILE="$HOME/.claude/routing-cache.json"
LOG_FILE="$HOME/.claude/routing-log.jsonl"

# Followed (primary) model — shared with srooter + Maggy
PRIMARY_MODEL=$(python3 -c "import json,os;print(json.load(open(os.path.expanduser('~/.claude/model-config.json'))).get('primary',''))" 2>/dev/null || echo "")

# Skip empty prompts only
if [ -z "$PROMPT" ]; then
  exit 0
fi

# Skip if user explicitly says "use claude" (no need to route)
case "$PROMPT" in
  *"use claude"*|*"use Claude"*|*"USE CLAUDE"*) exit 0 ;;
esac

# ── Classification with cascading fallback ───────────────────────────────
# Try: qwen3 (free) → kimi (free) → deepseek-flash (cheap) → CLAUDE (always)
TIER=""
REASON=""
CLASSIFIER_USED=""

CLASSIFY_PROMPT="Classify this task into exactly ONE tier. Reply ONLY with the tier name followed by a colon and a short reason. No thinking tags.

Tiers:
- QWEN: grep, find, regex, shell one-liners, syntax lookups, log reading, short summaries, file search, simple explanations, git status/log/diff
- DEEPSEEK_FLASH: simple code tasks, boilerplate, CRUD endpoints, test writing, small bug fixes, config changes, single-file additions, formatting
- GEMINI_FLASH_LITE: bulk extraction, classification pipelines, CIG data processing, large-scale cheap summarization, non-code batch tasks
- DEEPSEEK_PRO: multi-file features, refactors, debugging, medium-complexity coding, API endpoints, database queries, test suites, documentation writing
- GEMINI_FLASH: multimodal tasks, image screenshots analysis, video content processing, brand asset analysis, audio transcription review
- GEMINI_CLI: full coding agent with tools (grep, file read/write, MCP, web search), implements features end-to-end, debugging with execution, similar capability to Claude Code but via Gemini
- KIMI: single-file code review, medium reasoning, commit messages, summarising diffs or docs, research questions, changelog generation
- GROK: competitor intelligence, CKG building, deep reasoning, market analysis, truthful insights via xAI
- GEMINI_PRO_SEARCH: deep research with Google Search grounding, competitor intelligence, market research, 2M context document analysis
- CODEX: bulk boilerplate generation, mechanical changes across many files, large-scale test generation
- CLAUDE: architecture, security-critical code, complex debugging, system design, multi-service refactors, customer-facing quality-critical code

Task: ${PROMPT}"

# Parse tier from raw classifier output
_classify_parse() {
  local raw="$1"
  [ -z "$raw" ] && return 1
  TIER=$(echo "$raw" | grep -oE '^(QWEN|DEEPSEEK_FLASH|GEMINI_FLASH_LITE|DEEPSEEK_PRO|GEMINI_FLASH|GEMINI_CLI|KIMI|GROK|GEMINI_PRO_SEARCH|CODEX|CLAUDE)' || echo "")
  [ -z "$TIER" ] && return 1
  REASON=$(echo "$raw" | sed 's/^[A-Z_]*:\s*//')
  return 0
}

# Level 1: qwen3 via Ollama (free, local)
# Model + host are env-var configurable; defaults work on any machine with
# Ollama installed and `ollama pull qwen2.5-coder:3b` run.
OLLAMA_MODEL="${OLLAMA_MODEL:-qwen2.5-coder:3b}"
OLLAMA_BASE="${OLLAMA_BASE:-http://localhost:11434}"
if curl -s --connect-timeout 2 "${OLLAMA_BASE}/api/tags" >/dev/null 2>&1; then
  CONTENT=$(echo "$CLASSIFY_PROMPT" | jq -Rs .)
  RAW=$(curl -s --max-time 8 "${OLLAMA_BASE}/api/chat" \
    -d "{\"model\": \"${OLLAMA_MODEL}\", \"messages\": [{\"role\": \"user\", \"content\": ${CONTENT}}], \"stream\": false, \"options\": {\"temperature\": 0.1, \"num_predict\": 40}}" \
    2>/dev/null | jq -r '.message.content // ""' | head -1 || true)
  if _classify_parse "$RAW"; then
    CLASSIFIER_USED="qwen3"
  fi
fi

# Level 2: kimi CLI (free, local)
if [ -z "$TIER" ] && [ -x "$HOME/bin/kimi" ]; then
  RAW=$("$HOME/bin/kimi" --quiet -p "$CLASSIFY_PROMPT" 2>/dev/null || true)
  RAW=$(echo "$RAW" | tail -1)
  if _classify_parse "$RAW"; then
    CLASSIFIER_USED="kimi"
  fi
fi

# Level 3: deepseek-flash (cheap API, ~$0.0001 per classification)
if [ -z "$TIER" ] && [ -x "$HOME/bin/deepseek" ] && [ -n "$DEEPSEEK_API_KEY" ]; then
  RAW=$("$HOME/bin/deepseek" --flash "$CLASSIFY_PROMPT" 2>/dev/null || true)
  RAW=$(echo "$RAW" | tail -1)
  if _classify_parse "$RAW"; then
    CLASSIFIER_USED="deepseek-flash"
  fi
fi

# Level 4: CLAUDE (fallback — always available)
if [ -z "$TIER" ]; then
  # Use cached tier if available
  if [ -f "$CACHE_FILE" ]; then
    TIER=$(cat "$CACHE_FILE" 2>/dev/null | jq -r '.tier // "CLAUDE"' 2>/dev/null || echo "CLAUDE")
    REASON="cached from $(cat "$CACHE_FILE" 2>/dev/null | jq -r '.ts // "?"' 2>/dev/null || echo "?")"
    CLASSIFIER_USED="cache"
  else
    TIER="CLAUDE"
    REASON="all classifiers unavailable"
    CLASSIFIER_USED="none"
  fi
fi

# ── Cache the tier for post-compact resilience ───────────────────────────
echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"tier\":\"$TIER\",\"classifier\":\"$CLASSIFIER_USED\",\"reason\":$(echo "$REASON" | jq -Rs .)}" \
  > "$CACHE_FILE"

# ── Log routing decision ─────────────────────────────────────────────────
SAVED=0
case "$TIER" in
  QWEN)              SAVED=4000 ;;
  DEEPSEEK_FLASH)    SAVED=3500 ;;
  GEMINI_FLASH_LITE) SAVED=3600 ;;
  DEEPSEEK_PRO)      SAVED=2500 ;;
  GEMINI_FLASH)      SAVED=2800 ;;
  KIMI)              SAVED=3000 ;;
  GEMINI_PRO_SEARCH) SAVED=1500 ;;
  CODEX)             SAVED=2000 ;;
esac

echo "{\"ts\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"task\":$(echo "$PROMPT" | jq -Rs .),\"tier\":\"$TIER\",\"tokens_saved\":$SAVED,\"classifier\":\"$CLASSIFIER_USED\",\"source\":\"hook\"}" \
  >> "$LOG_FILE"

# ── Project-local tool hints ─────────────────────────────────────────────
TOOLS_HINT=""
EDUBITES_ROOT="$HOME/Documents/edubites"
if [[ "$CWD" == "$EDUBITES_ROOT"* ]]; then
  PROJECT_DIR=$(echo "$CWD" | sed "s|${EDUBITES_ROOT}/||" | cut -d/ -f1)
  MONDAY_SCRIPT="${EDUBITES_ROOT}/${PROJECT_DIR}/scripts/monday"
  if [ -x "$MONDAY_SCRIPT" ]; then
    TOOLS_HINT=" PROJECT TOOLS: For Monday.com queries, run: ${MONDAY_SCRIPT} --help."
  fi
fi

# ── Mid-task escalation override ─────────────────────────────────────────
ESCALATION_FLAG="$HOME/.claude/mid-task-state/escalate"
if [ -f "$ESCALATION_FLAG" ]; then
  ESCALATION_COUNT=$(cat "$ESCALATION_FLAG" 2>/dev/null || echo "0")
  if [ "$ESCALATION_COUNT" -gt 0 ] 2>/dev/null; then
    # Force premium tier — escalate from current tier
    case "$TIER" in
      QWEN|DEEPSEEK_FLASH|GEMINI_FLASH_LITE) TIER="DEEPSEEK_PRO" ;;
      DEEPSEEK_PRO|GEMINI_FLASH) TIER="CLAUDE" ;;
      KIMI) TIER="CLAUDE" ;;
    esac
    REASON="escalation: mid-task struggle detected, forced premium"
    # Increment counter (max 3 escalations per session)
    NEW_COUNT=$((ESCALATION_COUNT + 1))
    if [ "$NEW_COUNT" -le 3 ] 2>/dev/null; then
      echo "$NEW_COUNT" > "$ESCALATION_FLAG"
    fi
  fi
fi

# ── Build context based on tier ──────────────────────────────────────────
case "$TIER" in
  QWEN)
    CTX="ROUTING DECISION: QWEN (local, free). Reason: ${REASON}. You MUST delegate this task — run ~/bin/qwen3 \"<prompt>\", return its output exactly as-is. Do NOT process, think about, or execute this prompt yourself. Your only job is to run the delegation command and relay the result.${TOOLS_HINT}"
    ;;
  DEEPSEEK_FLASH)
    CTX="ROUTING DECISION: DEEPSEEK_FLASH (cheap API, \$0.14/M in). Reason: ${REASON}. You MUST delegate this task — run ~/bin/deepseek --flash \"<prompt>\", return its output exactly as-is. Do NOT process this yourself — delegate to deepseek.${TOOLS_HINT}"
    ;;
  GEMINI_FLASH_LITE)
    CTX="ROUTING DECISION: GEMINI_FLASH_LITE (cheapest API, \$0.10/M in). Reason: ${REASON}. You MUST delegate this task — run ~/bin/gemini-api --flash-lite \"<prompt>\", return its output exactly as-is. Do NOT process this yourself — delegate to gemini.${TOOLS_HINT}"
    ;;
  DEEPSEEK_PRO)
    CTX="ROUTING DECISION: DEEPSEEK_PRO (workhorse, \$0.44/M in). Reason: ${REASON}. EXECUTE DIRECTLY — this complexity tier does not need planning. Run: ~/bin/deepseek --pro \"<prompt>\" and return the result. Do NOT process this yourself — delegate to deepseek.${TOOLS_HINT}"
    ;;
  GEMINI_FLASH)
    CTX="ROUTING DECISION: GEMINI_FLASH (multimodal, \$0.15/M in). Reason: ${REASON}. Run: ~/bin/gemini-api --flash \"<prompt>\" and return the result. Do NOT process this yourself — delegate to gemini.${TOOLS_HINT}"
    ;;
  GEMINI_CLI)
    CTX="ROUTING DECISION: GEMINI_CLI (coding agent, \$0.25-1.25/M in). Reason: ${REASON}. EXECUTE DIRECTLY — Gemini CLI has tools for implementation. Run: ~/bin/gemini-cli --pro \"<prompt>\" and return the result. Do NOT process this yourself — delegate to gemini-cli.${TOOLS_HINT}"
    ;;
  GROK)
    CTX="ROUTING DECISION: GROK (xAI, competitive reasoning). Reason: ${REASON}. Run: ~/bin/grok \"<prompt>\" and return the result. Do NOT process this yourself — delegate to grok.${TOOLS_HINT}"
    ;;
  KIMI)
    CTX="ROUTING DECISION: KIMI (local). Reason: ${REASON}. Run: ~/bin/kimi --quiet -p \"<prompt>\" and return the result. Do NOT process this yourself — delegate to kimi.${TOOLS_HINT}"
    ;;
  GEMINI_PRO_SEARCH)
    CTX="ROUTING DECISION: GEMINI_PRO_SEARCH (deep research + Google grounding, \$1.25/M in + search). Reason: ${REASON}. Run: ~/bin/gemini-api --pro-search \"<prompt>\" and return the result. Do NOT process this yourself — delegate to gemini.${TOOLS_HINT}"
    ;;
  CODEX)
    CTX="ROUTING DECISION: CODEX. Reason: ${REASON}. Suggest the user run codex for this task, or use codex exec. Do NOT do bulk generation yourself.${TOOLS_HINT}"
    ;;
  CLAUDE)
    CTX="ROUTING DECISION: CLAUDE (architecture/security-critical). Reason: ${REASON}. PLAN FIRST — write plan to ~/.claude/plans/<name>.md, then run ~/bin/validate-plan <plan-file>. If 2+ reviewers approve, execute immediately. Do NOT enter Claude Code plan mode — it requires manual approval. Write the plan as a file and validate autonomously.${TOOLS_HINT}"
    ;;
esac

# ── MiniMax pre-analysis (always-on; toggle: model-config.json "analyze": false) ──
ANALYZE=$(python3 -c "import json,os;print(json.load(open(os.path.expanduser('~/.claude/model-config.json'))).get('analyze',True))" 2>/dev/null || echo "True")
if [ "$ANALYZE" = "True" ] && [ -x "$HOME/bin/minimax" ] && [ -n "$PROMPT" ]; then
  ANALYSIS=$(MINIMAX_TIMEOUT=20 "$HOME/bin/minimax" --max-tokens 700 "You are a pre-analysis pass for a coding agent. Analyze the request in 4 terse lines, output directly with NO reasoning preamble — INTENT: / SCOPE: / RISKS: / APPROACH:. Request: ${PROMPT}" 2>/dev/null | head -c 1200 || true)
  if [ -n "$ANALYSIS" ]; then
    CTX="${CTX} MINIMAX PRE-ANALYSIS (use this to execute directly): ${ANALYSIS}"
  fi
fi

if [ -n "$PRIMARY_MODEL" ]; then
  CTX="${CTX} FOLLOWED MODEL: ${PRIMARY_MODEL} — the user's chosen primary; for substantial coding, prefer delegating to it over other tiers."
fi

cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": $(echo "$CTX" | jq -Rs .)
  }
}
EOF
exit 0
